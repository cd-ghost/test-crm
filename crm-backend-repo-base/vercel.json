{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "crm-backend-repo-base/api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["crm-backend-repo-base/dist/**"]
      }
    },
    {
      "src": "crm-backend-repo-base/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "crm-backend-repo-base/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "crm-backend-repo-base/public/$1"
    }
  ]
}
